# ============================================================
# YouTube自動化パイプライン — 環境変数テンプレート
# ============================================================
# コピーして .env を作成し、実際の API KEY を入力してください。
# .env は .gitignore に含まれており、コミットされません。

# ============================================================
# Groq API （台本生成用）
# ============================================================
GROQ_API_KEY=your_groq_api_key_here
# https://console.groq.com から取得

# ============================================================
# YouTube API （投稿・メタデータ設定用）
# ============================================================
YOUTUBE_API_KEY=your_youtube_api_key_here
# Google Cloud Console → YouTube Data API v3 から取得
# https://console.cloud.google.com

# OAuth トークンファイルパス（generate_token.py で生成）
YOUTUBE_TOKEN_FILE=/home/ec2-user/task/03_PROJECTS/youtube_automation/token.json
# ローカルで generate_token.py を実行 → SCP で EC2 にコピー

# ============================================================
# Pexels API （映像素材取得用）
# ============================================================
PEXELS_API_KEY=your_pexels_api_key_here
# https://www.pexels.com/api/ から取得

# ============================================================
# VOICEVOX （音声生成用）
# ============================================================
VOICEVOX_URL=http://localhost:50021
# ローカル: localhost:50021
# Docker: http://voicevox:50021
# クラウド: https://voicevox.example.com（自分でホスト）

# ============================================================
# AWS S3 （出力保存用・オプション）
# ============================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET=your-youtube-automation-bucket
# 出力動画を S3 にバックアップしたい場合のみ設定

# ============================================================
# アプリケーション設定
# ============================================================
LOG_LEVEL=INFO
# DEBUG / INFO / WARNING / ERROR

OUTPUT_DIR=./out
# 出力ディレクトリ（相対パス or 絶対パス）

TEMP_DIR=./tmp
# 一時ファイルディレクトリ

# ============================================================
# YouTube 投稿設定
# ============================================================
YOUTUBE_PUBLISH_MODE=SCHEDULE
# SCHEDULE: 予約公開（翌日朝6時）
# PRIVATE: 非公開保存（手動投稿）
# PUBLIC: 即座に公開（テスト時のみ推奨）

YOUTUBE_PUBLISH_HOUR=6
# 予約公開の時刻（24時間制）

# ============================================================
# パイプライン設定
# ============================================================
TARGET_THEME=auto
# auto: トレンド自動分析
# finance: 金融・投資・節約
# tech: テック・AI
# business: ビジネス・自己啓発

VIDEO_DURATION_MIN=8
VIDEO_DURATION_MAX=12
# 動画尺（分）

LANGUAGE=ja
# ja: 日本語
# en: 英語
